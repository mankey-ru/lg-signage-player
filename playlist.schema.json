{
	"$schema": "http://json-schema.org/draft-07/schema#",
	"title": "Signage Playlist Schema",
	"type": "object",
	"required": ["version", "items"],
	"properties": {
		"version": {
			"type": "string",
			"description": "Версия формата плейлиста"
		},
		"updated": {
			"type": "string",
			"format": "date-time",
			"description": "Дата последнего обновления"
		},
		"items": {
			"type": "array",
			"minItems": 1,
			"items": {
				"type": "object",
				"required": ["type", "url"],
				"properties": {
					"type": {
						"type": "string",
						"enum": ["video", "image", "web"]
					},
					"url": {
						"type": "string",
						"format": "uri",
						"description": "Прямая ссылка на файл или страницу"
					},
					"duration": {
						"type": "integer",
						"minimum": 5,
						"description": "Длительность в секундах (только для image)"
					},
					"title": {
						"type": "string",
						"description": "Название для логов и отладки"
					},
					"startTime": {
						"type": "string",
						"format": "time",
						"description": "Время начала показа (опционально)"
					},
					"endTime": {
						"type": "string",
						"format": "time",
						"description": "Время окончания показа (опционально)"
					}
				}
			}
		}
	}
}
